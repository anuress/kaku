    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "dev": "bun run src/index.ts",
    "test": "bun test"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@anuress/kaku-protocol": "^0.1.7",
    "@types/node": "^18.0.0",
    "@types/ws": "^8.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
