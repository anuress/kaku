{
  "name": "@anuress/kaku-server",
  "version": "0.1.2",
  "description": "Relay server for kaku — the mobile app debug engine",
  "type": "commonjs",
  "bin": { "kaku-server": "./dist/index.js" },
  "main": "./dist/index.js",
  "files": ["dist"],
  "publishConfig": { "access": "public" },
  "exports": { ".": "./dist/index.js" },
  "engines": { "node": ">=18" },
